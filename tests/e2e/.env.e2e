# E2E test environment — mock services on host, agent in k3d
GITLAB_URL=http://host.k3d.internal:9999
GITLAB_TOKEN=e2e-fake-token
GITLAB_WEBHOOK_SECRET=e2e-test-secret
GITHUB_TOKEN=e2e-fake-gh-token
COPILOT_PROVIDER_TYPE=openai
COPILOT_PROVIDER_BASE_URL=http://host.k3d.internal:9998/v1
COPILOT_PROVIDER_API_KEY=e2e-fake-key
ALLOW_HTTP_CLONE=true
GITLAB_POLL=true
GITLAB_POLL_INTERVAL=5
GITLAB_PROJECTS=999
JIRA_URL=http://host.k3d.internal:9997
JIRA_EMAIL=e2e@test.com
JIRA_API_TOKEN=e2e-fake-jira-token
JIRA_PROJECT_MAP='{"mappings": {"DEMO": {"repo": "repo", "target_branch": "main", "credential_ref": "default"}}}'
JIRA_TRIGGER_STATUS="AI Ready"
JIRA_POLL_INTERVAL=5
COPILOT_PLUGINS=/opt/test-marketplace/plugins/e2e-greeter
COPILOT_PLUGIN_MARKETPLACES=/opt/test-marketplace
